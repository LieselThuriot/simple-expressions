{
  "name": "simple-expressions",
  "version": "0.1.1",
  "description": "Simple expression parsing and execution",
  "main": "lib/index.js",
  "types": "./lib/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "parser",
    "lexer",
    "script",
    "execution"
  ],
  "author": "Liesel Thuriot",
  "license": "ISC",
  "scripts": {
    "build": "node scripts/clean.js && tsc && terser lib/index.js --compress --mangle --output lib/index.js",
    "test": "npm run build && vitest run",
    "demo": "vite --config demo/vite.config.js",
    "demo:build": "vite build --config demo/vite.config.js",
    "demo:preview": "vite preview --config demo/vite.config.js",
    "pack:check": "npm pack --dry-run",
    "release": "npm pack && npm publish",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LieselThuriot/simple-expressions.git"
  },
  "bugs": {
    "url": "https://github.com/LieselThuriot/simple-expressions/issues"
  },
  "homepage": "https://github.com/LieselThuriot/simple-expressions#readme"
}
